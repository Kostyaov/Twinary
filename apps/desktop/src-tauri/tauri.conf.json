{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "BackupFlow",
  "version": "1.0.0",
  "identifier": "com.backupflow.desktop",
  "build": {
    "beforeDevCommand": "npm run dev",
    "devUrl": "http://localhost:1420",
    "beforeBuildCommand": "npm run build",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "title": "BackupFlow",
        "width": 1180,
        "height": 780,
        "minWidth": 920,
        "minHeight": 640
      }
    ]
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/icon.png",
      "icons/icon.ico"
    ]
  }
}
